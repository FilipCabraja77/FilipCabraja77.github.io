# ====================================================================
# Foka Diving Center - Apache config for Hostinger
# ====================================================================
Options -Indexes +FollowSymLinks
DirectoryIndex index.html

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Force non-www (canonical host)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# --- Clean URLs: serve /slug/ from /slug/index.html (folder layout already
#     does this via DirectoryIndex). Strip a trailing "index.html". ---
RewriteCond %{THE_REQUEST} \s/(.+/)?index\.html[\s?] [NC]
RewriteRule ^(.+/)?index\.html$ /%1 [R=301,L]

# Remove a literal ".html" if ever requested, redirect to trailing-slash dir
RewriteCond %{THE_REQUEST} \s/(.+)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1/ [R=301,L]

# --- 301 redirects for changed slugs (preserve SEO) ---
# Croatian prices slug was the German word "preise"
Redirect 301 /hr/preise/ /hr/cijene/
# Team year-in-slug cleanup (EN/root + DE both dropped the "-2023")
Redirect 301 /team-2023/ /team/
Redirect 301 /de/team-2023/ /de/team/
# Center in Straško: old slug used "novalja" (EN kept, HR/DE localized)
Redirect 301 /hr/center-in-novalja/ /hr/centar-u-strasku/
Redirect 301 /de/center-in-novalja/ /de/zentrum-in-strasko/
# Lift-bags article: Croatian text that used to sit at the root (EN) URL; it is
# now published as the Croatian article it is, same slug under /hr/.
Redirect 301 /upotreba-ronilackih-balona-padobrana-ronilacki-padobrani-korisni-ali-ne-i-bezazleni/ /hr/upotreba-ronilackih-balona-padobrana-ronilacki-padobrani-korisni-ali-ne-i-bezazleni/

# --- Sitemap-gap redirects (27 URLs uncovered in the old foka.hr sitemap) ---
# CRITICAL: the real old German slug for the Straško center (keeps its ranking)
Redirect 301 /de/tauchzentrum-in-strasko/ /de/zentrum-in-strasko/

# WordPress category archives -> nearest per-language landing
Redirect 301 /category/blog/ /blog/
Redirect 301 /hr/category/blog-hr/ /hr/blog/
Redirect 301 /category/boat-diving/ /boat-dive/
Redirect 301 /category/boat-diving-away/ /boat-dive/
Redirect 301 /category/boat-diving-maun/ /boat-dive/
Redirect 301 /category/boat-diving-special/ /boat-dive/
Redirect 301 /hr/category/ronjenje-s-broda/ /hr/ronjenje-s-broda/
Redirect 301 /hr/category/ronjenje-s-broda-hr/ /hr/ronjenje-s-broda/
Redirect 301 /hr/category/ronjenje-s-broda-maun/ /hr/ronjenje-s-broda/
Redirect 301 /hr/category/specijalno-ronjenje-s-broda/ /hr/ronjenje-s-broda/
Redirect 301 /de/category/bootstauchen/ /de/bootstauchen/
Redirect 301 /de/category/boot-taucht-weg/ /de/bootstauchen/
Redirect 301 /de/category/bootstauchen-maun/ /de/bootstauchen/
Redirect 301 /de/category/bootstauchen-special/ /de/bootstauchen/
Redirect 301 /category/shore-dive/ /shore-dive/
Redirect 301 /hr/category/ronjenje-s-obale/ /hr/ronjenje-s-obale/
Redirect 301 /de/category/kustentauchen/ /de/kuestentauchen/
Redirect 301 /category/galerija/ /gallery/
Redirect 301 /hr/category/galerija-hr/ /hr/galerija/
Redirect 301 /de/category/galerie/ /de/galerie/
Redirect 301 /category/projekti/ /projects/
Redirect 301 /hr/category/projekti-hr/ /hr/projekti/
Redirect 301 /de/category/projekti-de/ /de/projekte/

# WordPress author archives + a stray 404 artifact
Redirect 301 /author/fokadoo/ /aboutus-foka/
Redirect 301 /author/tjadmin/ /aboutus-foka/
Redirect 301 /error-404-page/ /

# --- Caching / compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/html "access plus 1 day"
</IfModule>

# --- Custom error pages, per language ---
# ErrorDocument takes one static path, so a single global rule would answer a bad
# /hr/ or /de/ URL with the English page. ErrorDocument is a per-directory
# directive, so the fix is a small .htaccess inside dist/hr/ and dist/de/ (written
# by build.js): Apache reads the .htaccess of the directory the request maps to
# and uses that language's document. The response keeps a real 404 status: this is
# an internal error document, not a redirect (no 302) and not a normal page (no 200).
#
# Note on the mod_rewrite alternative: "RewriteRule ^ /hr/404.html [R=404,L]" does
# NOT serve that file. R=404 only sets the status and Apache then falls back to the
# global ErrorDocument, while an internal rewrite without R would answer 200. The
# per-directory ErrorDocument is the approach that gives both the right document
# and the right status.
#
# HOW TO TEST ON HOSTINGER (after upload):
#   curl -I https://foka.hr/ovo-ne-postoji/     -> HTTP/1.1 404, English page
#   curl -I https://foka.hr/hr/ovo-ne-postoji/  -> HTTP/1.1 404, Croatian page
#   curl -I https://foka.hr/de/gibt-es-nicht/   -> HTTP/1.1 404, German page
#   curl -s https://foka.hr/hr/ovo-ne-postoji/ | grep "<html lang"  -> lang="hr"
# In a browser: open the same URLs and check the Network tab shows Status 404
# (not 302, not 200). If Hostinger ever ignores the nested files, the same result
# can be forced from this file with mod_setenvif + <If> blocks (Apache 2.4).
ErrorDocument 404 /404.html

# ====================================================================
# Security headers
# --------------------------------------------------------------------
# The CSP below was derived from an inventory of what dist/ actually uses:
#   - 1 inline <script> (the bootstrap in <head>, identical on all 177 pages)
#     -> allowed by its sha256 hash, so scripts never need 'unsafe-inline'
#   - 2 external scripts, 1 stylesheet, all first-party  -> 'self'
#   - 378 JSON-LD blocks (application/ld+json)           -> not executable, not
#     governed by script-src, so they need no hash
#   - 354 inline style="" attributes (map pins, layout)  -> style-src needs
#     'unsafe-inline'; there is no inline <script> handler anywhere (0 onclick)
#   - images: first-party only (+ data: for CSS-generated assets)
#   - the Google Maps iframe, injected only after the visitor clicks "Load map"
#     -> frame-src https://www.google.com
#   - the contact form: fetch() and native POST to /api/contact.php -> 'self'
# If you add an external script, font or embed, this policy must be updated or
# the browser will block it.
# ====================================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=()"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-ALSij2VcelQUiS4sF/3byC7llshuKfunY2DBYtlJSgY='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-src https://www.google.com; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>
